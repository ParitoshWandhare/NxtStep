# ============================================================
# NxtStep Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=5000
CLIENT_URL=http://localhost:5173  # Frontend URL for CORS & email links

# ─── Database ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nxtstep
# Production example:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nxtstep?retryWrites=true&w=majority

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# With password:
# REDIS_URL=redis://:your_password@localhost:6379
# Redis Cloud / Upstash:
# REDIS_URL=rediss://default:your_password@your-host.upstash.io:6380

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_here
JWT_EXPIRES_IN=7d                  # Main token lifetime
JWT_EPHEMERAL_EXPIRES_IN=2h        # Interview session token lifetime

# ─── AI Provider (OpenRouter) ────────────────────────────────
# Get your key at: https://openrouter.ai/keys
# Leave blank to use mock responses in development
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Recommended models (balance cost vs quality):
#   mistralai/mistral-7b-instruct:free    — Free tier, good for dev
#   openai/gpt-4o-mini                   — Fast, cheap, good quality
#   anthropic/claude-3-haiku              — High quality, reasonable cost
#   meta-llama/llama-3-8b-instruct:free  — Free tier alternative
OPENROUTER_DEFAULT_MODEL=mistralai/mistral-7b-instruct:free

# ─── Speech (Optional) ───────────────────────────────────────
STT_PROVIDER=webspeech      # webspeech | deepgram | assemblyai
TTS_PROVIDER=browser        # browser | elevenlabs

# Deepgram (if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# ElevenLabs (if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=

# ─── News APIs (Optional — RSS works without these) ──────────
# GNews: https://gnews.io/
GNEWS_API_KEY=

# NewsAPI: https://newsapi.org/
NEWSAPI_KEY=

# ─── Email / SMTP ────────────────────────────────────────────
# Leave blank to log emails to console (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here   # Use app password, NOT your Gmail password
SMTP_FROM=noreply@nxtstep.app

# Alternatives:
# Resend:    SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_USER=resend  SMTP_PASS=re_xxx
# SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASS=SG.xxx
# Mailgun:   SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587  SMTP_USER=postmaster@mg.domain.com

# ─── File Uploads ────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ─── Scoring Weights (must sum to 1.0) ───────────────────────
WEIGHT_TECHNICAL=0.35
WEIGHT_PROBLEM_SOLVING=0.25
WEIGHT_COMMUNICATION=0.20
WEIGHT_CONFIDENCE=0.10
WEIGHT_CONCEPT_DEPTH=0.10

# ─── Recommendation Matching Weights (must sum to 1.0) ───────
WEIGHT_SKILL_MATCH=0.50
WEIGHT_LEVEL_MATCH=0.20
WEIGHT_PREFERENCE_MATCH=0.15
WEIGHT_RESUME_MATCH=0.15

# ─── Proctoring Thresholds ───────────────────────────────────
TAB_SWITCH_WARN_THRESHOLD=3        # Warn after N tab switches
TAB_SWITCH_TERMINATE_THRESHOLD=5   # Terminate after N tab switches
CAMERA_WARN_SECONDS=10             # Warn if face absent > N seconds
CAMERA_LOG_SECONDS=30              # Log if face absent > N seconds
CAMERA_TERMINATE_SECONDS=60        # Terminate if face absent > N seconds

# ─── Interview Engine ─────────────────────────────────────────
MAX_QUESTIONS_PER_SESSION=10       # Max primary questions per interview
MAX_FOLLOWUPS_PER_QUESTION=2       # Max follow-ups per question
CONFIDENCE_FOLLOWUP_THRESHOLD=5    # Trigger follow-up if confidence < N
CONCEPT_DEPTH_FOLLOWUP_THRESHOLD=5 # Trigger follow-up if concept depth < N

# ─── Rate Limiting ───────────────────────────────────────────
# These are the defaults; adjust based on your infrastructure
RATE_LIMIT_GLOBAL_MAX=200          # Requests per 15 minutes (global)
RATE_LIMIT_AUTH_MAX=20             # Requests per 15 minutes (auth endpoints)
RATE_LIMIT_INTERVIEW_MAX=60        # Requests per minute (interview events)

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info                     # fatal | error | warn | info | debug | trace

# ─── Monitoring (Optional) ───────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=

# ─── Worker Process ──────────────────────────────────────────
# These are used by the separate worker process (npm run worker)
NEWS_INGESTION_INTERVAL_MINUTES=10   # How often to ingest news
WORKER_CONCURRENCY_EVALUATE=5        # Concurrent answer evaluation jobs
WORKER_CONCURRENCY_GENERATE=5        # Concurrent question generation jobs
WORKER_CONCURRENCY_SCORECARD=3       # Concurrent scorecard computation jobs
WORKER_CONCURRENCY_RECOMMEND=3       # Concurrent recommendation jobs

# ─── Security ────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12               # Higher = more secure but slower (10-14 recommended)
PASSWORD_RESET_EXPIRES_HOURS=1      # Password reset token expiry

# ─── Cache TTLs (seconds) ────────────────────────────────────
CACHE_TTL_NEWS_FEED=120             # News feed cache (2 minutes)
CACHE_TTL_TRENDING=300              # Trending news cache (5 minutes)
CACHE_TTL_ROLE_ENRICHMENT=86400     # Role AI descriptions (24 hours)

# ─── Trust Proxy ─────────────────────────────────────────────
# Set to '1' if behind a reverse proxy (Nginx, Render, Railway, etc.)
TRUST_PROXY=1
