{
  "name": "nxtstep-backend",
  "version": "1.0.0",
  "description": "NxtStep AI Interview Platform — Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev":          "tsx watch src/app.ts",
    "dev:worker":   "tsx watch src/workers/index.ts",
    "build":        "tsc --project tsconfig.json",
    "start":        "node dist/app.js",
    "worker":       "node dist/workers/index.js",
    "lint":         "eslint src --ext .ts",
    "lint:fix":     "eslint src --ext .ts --fix",
    "typecheck":    "tsc --noEmit",
    "test":         "jest --runInBand",
    "test:watch":   "jest --watch",
    "test:coverage":"jest --coverage",
    "clean":        "rimraf dist"
  },
  "dependencies": {
    "axios":           "^1.7.2",
    "bcryptjs":        "^2.4.3",
    "bullmq":          "^5.12.0",
    "cors":            "^2.8.5",
    "dotenv":          "^16.4.5",
    "express":         "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":          "^7.1.0",
    "ioredis":         "^5.4.1",
    "jsonwebtoken":    "^9.0.2",
    "mongoose":        "^8.4.0",
    "node-cron":       "^3.0.3",
    "nodemailer":      "^6.9.13",
    "pino":            "^9.2.0",
    "pino-http":       "^10.2.0",
    "pino-pretty":     "^11.2.1",
    "rss-parser":      "^3.13.0",
    "socket.io":       "^4.7.5",
    "uuid":            "^10.0.0",
    "zod":             "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node":         "^20.14.0",
    "@types/node-cron":    "^3.0.11",
    "@types/nodemailer":   "^6.4.15",
    "@types/uuid":         "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser":        "^7.13.0",
    "eslint":    "^8.57.0",
    "jest":      "^29.7.0",
    "rimraf":    "^5.0.7",
    "ts-jest":   "^29.1.4",
    "tsx":       "^4.15.6",
    "typescript":"^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}