# ============================================================
# NxtStep Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nxtstep
# Production example:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nxtstep?retryWrites=true&w=majority

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
# Ephemeral tokens are used per interview session (2h, scoped audience)

# ── AI / LLM ─────────────────────────────────────────────────
# Provider: openrouter | openai | local
AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-4o-mini
AI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://openrouter.ai/api/v1
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=3

# For OpenAI direct:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.openai.com/v1

# For local Ollama:
# AI_PROVIDER=local
# AI_MODEL=mistral
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama

# ── SMTP / Email ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@nxtstep.io
PASSWORD_RESET_EXPIRES_HOURS=2

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_RESUME_SIZE_MB=5
MAX_AUDIO_SIZE_MB=50

# ── News APIs ─────────────────────────────────────────────────
# At least one is recommended; RSS feeds work without any key
NEWS_API_KEY=
GNEWS_API_KEY=
# Ingestion interval in milliseconds (default: 10 minutes)
NEWS_INGEST_INTERVAL_MS=600000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
INTERVIEW_MAX_PER_HOUR=5

# ── Interview Engine ──────────────────────────────────────────
INTERVIEW_MAX_QUESTIONS=10
INTERVIEW_MAX_FOLLOWUPS_PER_QUESTION=2

# ── Proctoring Thresholds ─────────────────────────────────────
PROCTORING_MAX_TAB_SWITCHES=5
PROCTORING_FACE_WARN_SECONDS=10
PROCTORING_FACE_LOG_SECONDS=30
PROCTORING_FACE_TERMINATE_SECONDS=60

# ── Scoring Weights (must sum to 1.0) ─────────────────────────
SCORE_WEIGHT_TECHNICAL=0.35
SCORE_WEIGHT_PROBLEM_SOLVING=0.25
SCORE_WEIGHT_COMMUNICATION=0.20
SCORE_WEIGHT_CONFIDENCE=0.10
SCORE_WEIGHT_CONCEPT_DEPTH=0.10

# ── Recommendation Weights (must sum to 1.0) ──────────────────
RECOMMEND_WEIGHT_SKILL=0.50
RECOMMEND_WEIGHT_LEVEL=0.20
RECOMMEND_WEIGHT_PREFERENCE=0.15
RECOMMEND_WEIGHT_RESUME=0.15

# ── Workers ───────────────────────────────────────────────────
ENABLE_WORKERS=true
ENABLE_NEWS_INGESTION=true
WORKER_CONCURRENCY=4

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
# In development, logs are pretty-printed. In production, JSON.
