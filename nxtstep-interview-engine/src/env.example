# NxtStep Interview Engine — Environment Variables
# Copy to .env and fill in values

# ─── Server ─────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── AI Provider ────────────────────────────────────────
# Leave blank to use mock responses (dev mode)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# To switch to OpenAI directly:
# AI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_API_KEY=sk-...
# OPENROUTER_MODEL=gpt-4o-mini

# ─── Interview Engine Tuning ─────────────────────────────
MAX_QUESTIONS=8
MAX_FOLLOWUPS_PER_QUESTION=2
CONFIDENCE_FOLLOWUP_THRESHOLD=5
CONCEPT_DEPTH_FOLLOWUP_THRESHOLD=5
